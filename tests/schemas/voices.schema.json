{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "voices.json schema",
  "description": "Validates voice data — critical fields strict, optional fields permissive (empty string allowed)",
  "type": "object",
  "required": ["groups"],
  "properties": {
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "group_name", "group_description", "voice_list"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "group_name": { "type": "string", "minLength": 1 },
          "group_description": {
            "type": "object",
            "required": ["zh", "ja", "en"],
            "properties": {
              "zh": { "type": "string", "minLength": 1 },
              "ja": { "type": "string", "minLength": 1 },
              "en": { "type": "string", "minLength": 1 }
            }
          },
          "voice_list": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "path", "description"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "name": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "pattern": "\\.(mp3|ogg)$" },
                "url": { "type": "string" },
                "year": { "type": "string", "pattern": "^(\\d{4})?$" },
                "description": {
                  "type": "object",
                  "required": ["zh", "ja", "en"],
                  "properties": {
                    "zh": { "type": "string", "minLength": 1 },
                    "ja": { "type": "string", "minLength": 1 },
                    "en": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
