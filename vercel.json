{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm generate",
  "routes": [
    {
      "src": "/voices/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/img/(.*)",
      "headers": { "cache-control": "public, max-age=2592000" },
      "continue": true
    },
    {
      "src": "/(banner|icon|favicon).*\\.(jpe?g|png|ico|svg|webp|avif)$",
      "headers": { "cache-control": "public, max-age=2592000" },
      "continue": true
    },
    {
      "src": "/(android-chrome|apple-touch-icon).*\\.(png|jpe?g|webp)$",
      "headers": { "cache-control": "public, max-age=2592000" },
      "continue": true
    }
  ]
}
